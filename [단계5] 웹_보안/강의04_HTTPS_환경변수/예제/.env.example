# ============================================
# 환경변수 템플릿 (.env.example)
# ============================================
# 사용법:
#   cp .env.example .env
#   .env 파일을 열고 실제 값으로 교체
#
# 주의사항:
#   - .env 파일은 절대 Git에 커밋하지 마세요!
#   - .gitignore에 .env를 추가했는지 확인하세요.
#   - 이 파일(.env.example)은 실제 값이 없으므로 Git에 포함해도 됩니다.
# ============================================

# ── 서버 설정 ──
NODE_ENV=development        # development | production
PORT=3000

# ── 데이터베이스 ──
# MongoDB Atlas 연결 문자열
# 예: mongodb+srv://username:password@cluster0.abcde.mongodb.net/myDatabase
DATABASE_URL=your_mongodb_connection_string_here

# SQLite는 환경변수 불필요 (파일 경로만)
SQLITE_PATH=./data/app.db

# ── 인증 ──
# 최소 32자 이상의 랜덤 문자열 권장
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

SESSION_SECRET=replace_with_another_long_random_string

# ── 외부 API 키 ──
# 각 서비스의 대시보드에서 발급
OPENAI_API_KEY=sk-your-api-key-here
STRIPE_SECRET_KEY=sk_test_your_stripe_key
KAKAO_API_KEY=your_kakao_api_key
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── 이메일 서비스 ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── AWS (사용하는 경우) ──
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-bucket-name
