# ============================================
# 과제04 정답: 환경변수 템플릿
# ============================================
# 사용법:
#   cp .env.example .env
#   .env 파일에서 실제 값으로 교체
#
# 보안 원칙:
#   - .env 파일은 절대 Git에 커밋하지 않는다
#   - .gitignore에 .env가 있는지 항상 확인
#   - 이 파일(.env.example)은 실제 값이 없으므로 Git에 포함해도 됨
#   - 팀원에게 .env를 이메일로 공유하지 말 것 (안전한 채널 사용)
# ============================================

# ── 서버 기본 설정 ──
NODE_ENV=development
PORT=3000

# ── 데이터베이스 연결 문자열 ──
# MongoDB Atlas: 대시보드 > Connect > Connect your application
# 예시 형식: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/dbname
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.xxxxx.mongodb.net/your_db

# ── 인증 시크릿 ──
# 생성 명령어:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 최소 32자 이상의 랜덤 문자열 사용

# JWT 토큰 서명에 사용되는 시크릿 키
JWT_SECRET=replace_with_64_char_random_hex_string_here

# 세션 쿠키 서명에 사용되는 시크릿
SESSION_SECRET=replace_with_another_64_char_random_hex_string

# ── 외부 API 키 ──
# 각 서비스의 개발자 대시보드에서 발급

# 외부 데이터 API 키 (예시)
EXTERNAL_API_KEY=your_api_key_here

# ── 이메일 (선택) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
